{
  "Jwt": {
    "Key": "",
    "Issuer": "",
    "Audience": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Grafana.Loki" ],
    "MinimumLevel": {
      "Default": "Information"
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "${LOKI_URL}",
          "login": "${LOKI_USERNAME}",
          "password": "${LOKI_PASSWORD}",
          "labels": [
            { "key": "app", "value": "pm-api" },
            { "key": "env", "value": "development" }
          ]
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}